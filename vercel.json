{
  "version": 2,
  "functions": {
    "server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*\\.js)",
      "dest": "/$1",
      "runtime": "static"
    },
    {
      "src": "/(.*\\.css)",
      "dest": "/$1",
      "runtime": "static"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
